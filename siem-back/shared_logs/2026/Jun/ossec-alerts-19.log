led","c:systemctl status aidecheck.timer -> r:enabled"],"condition":"any","references":"https://github.com/konstruktoid/hardening/blob/master/config/aidecheck.service,https://github.com/konstruktoid/hardening/blob/master/config/aidecheck.timer","command":"crontab -u root -l,grep -r aide /etc/cron.* /etc/crontab,systemctl is-enabled aidecheck.service,systemctl is-enabled aidecheck.timer,systemctl status aidecheck.timer","status":"Not applicable","reason":"Invalid path or wrong permissions to run command 'crontab -u root -l'"}}
