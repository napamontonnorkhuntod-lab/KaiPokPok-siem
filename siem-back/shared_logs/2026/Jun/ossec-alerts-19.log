"M1022"},"rules":["d:/etc/audit/rules.d","d:/etc/audit/rules.d -> r:\\.+.rules$","d:/etc/audit/rules.d -> r:\\.+.rules$ -> r:^-a && r:always,exit|exit,always && r:-F path=/usr/sbin/usermod && r:-F perm=x && r:-F auid>=\\d+ && r:-F auid!=-1|-F auid!=4294967295|-F auid!=unset && r:-k usermod|-F key=usermod","c:auditctl -l -> r:^-a && r:always,exit|exit,always && r:-F path=/usr/sbin/usermod && r:-F perm=x && r:-F auid>=\\d+ && r:-F auid!=-1|-F auid!=4294967295|-F auid!=unset && r:-k usermod|-F key=usermod"],"condition":"all","directory":"/etc/audit/rules.d","result":"failed"}}
